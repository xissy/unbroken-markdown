{
  "name": "unbroken-markdown",
  "version": "0.2.0",
  "type": "module",
  "description": "Fix broken markdown formatting by moving punctuation outside bold/italic text and removing incomplete image markdown during streaming",
  "keywords": [
    "markdown",
    "streaming",
    "formatting",
    "typography",
    "punctuation",
    "renderer",
    "fix",
    "sanitize"
  ],
  "author": "Taeho Kim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xissy/unbroken-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/xissy/unbroken-markdown/issues"
  },
  "homepage": "https://github.com/xissy/unbroken-markdown#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml}\"",
    "prepublishOnly": "bun run build && bun run test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.30.1",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
